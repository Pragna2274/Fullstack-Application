generator client {
  provider = "prisma-client-js"
  output="../generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  image       String
  category    String
  createdAt   DateTime @default(now())
}